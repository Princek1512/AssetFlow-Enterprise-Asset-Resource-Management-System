# --- Database ---
# Async driver (used by the app at runtime)
DATABASE_URL=postgresql+asyncpg://assetflow_user:changeme@localhost:5432/assetflow
# Sync driver (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://assetflow_user:changeme@localhost:5432/assetflow

# --- Security / JWT ---
SECRET_KEY=change-this-to-a-long-random-string-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App ---
ENVIRONMENT=development
PROJECT_NAME=AssetFlow
API_V1_PREFIX=/api/v1

# --- Bootstrap Admin (created on first startup if no admin exists) ---
FIRST_ADMIN_EMAIL=admin@assetflow.local
FIRST_ADMIN_PASSWORD=ChangeMe123!
FIRST_ADMIN_NAME=System Administrator
